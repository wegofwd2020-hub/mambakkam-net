# build output
dist/
.output/

# dependencies
node_modules/

# ...but the Mentible web demo export bundles fonts under an
# assets/node_modules/ path; those are real artifacts that must be committed
# and served (otherwise the app hangs loading fonts). Re-include them.
!public/demos/mentible/assets/node_modules/
!public/demos/mentible/assets/node_modules/**

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

pnpm-lock.yaml

.astro

# Nightly doc-index drift report — regenerated every run; commit if you want
# history, otherwise leave as a working-tree artefact. See
# scripts/docs_index/README.md.
DRIFT_REPORT.md
