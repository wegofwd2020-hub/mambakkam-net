---
/**
 * Shared content-generation engine diagram for the "What I'm Building" section.
 *
 * Tells the real dependency story from the WeGoFwd2020 shared-library graph:
 * one engine (wegofwd-llm) is proven in Mentible first, then reused across the
 * other products. Solid edge = the dependency is wired in code today; dashed =
 * planned. This is why Pramana reads "in build" rather than deployed — the
 * engine it leans on is still being matured in Mentible.
 *
 * Same conventions as LearningDiagram.astro: the SVG is inlined so dark-mode
 * rules key off the site's `.dark` class (not the OS), and every selector is
 * nested under `.engine-diagram` so the SVG's bare selectors can't repaint the
 * rest of the page. Astro also scopes the block automatically.
 */
---

<figure class="engine-diagram">
  <svg viewBox="0 0 680 300" role="img" xmlns="http://www.w3.org/2000/svg">
    <title>One shared content-generation engine, proven in Mentible, then reused across the products</title>
    <desc>
      A single shared library, wegofwd-llm, is the content-generation engine, shown on the left. It flows to three
      products on the right in order of maturity: Mentible (live) — where the engine is proven; Pramana (in build),
      which reuses it; and Kathai Chithiram (in build), for which it is planned. Solid arrows mark dependencies wired in
      code today; the dashed arrow marks a planned one.
    </desc>

    {/* Engine (left) */}
    <rect class="engine-b" x="24" y="110" width="176" height="72" rx="8"></rect>
    <text class="node teal-t" x="112" y="142" text-anchor="middle">wegofwd-llm</text>
    <text class="teal-t sub" x="112" y="161" text-anchor="middle">shared content-generation engine</text>

    {/* Edges: a shared trunk out of the engine that splits into three at the bend point */}
    {/* to Mentible (solid, proven) — elbow up */}
    <path class="ln" d="M200 146 H300 V68 H401" fill="none"></path>
    <polygon class="ah" points="405,68 396,64 397,72"></polygon>
    <text class="elabel" x="352" y="60" text-anchor="middle">proven</text>
    {/* to Pramana (solid, reused) — straight */}
    <path class="ln" d="M200 146 H401" fill="none"></path>
    <polygon class="ah" points="405,146 397,142 397,150"></polygon>
    <text class="elabel" x="345" y="139" text-anchor="middle">reused</text>
    {/* to Kathai Chithiram (dashed, planned) — elbow down */}
    <path class="ln dashed" d="M200 146 H300 V224 H401" fill="none"></path>
    <polygon class="ah-muted" points="405,224 396,220 397,228"></polygon>
    <text class="elabel muted" x="352" y="240" text-anchor="middle">planned</text>
    {/* junction where the trunk splits */}
    <circle class="junction" cx="300" cy="146" r="3"></circle>

    {/* Products (right, top→bottom = live→in build) */}
    {/* Mentible */}
    <rect class="prod-b" x="405" y="40" width="250" height="56" rx="8"></rect>
    <text class="node prod-t" x="422" y="73" text-anchor="start">Mentible</text>
    <rect class="chip-live" x="560" y="57" width="80" height="22" rx="11"></rect>
    <text class="chip-live-t" x="600" y="72" text-anchor="middle">live</text>

    {/* Pramana */}
    <rect class="prod-b" x="405" y="118" width="250" height="56" rx="8"></rect>
    <text class="node prod-t" x="422" y="151" text-anchor="start">Pramana</text>
    <rect class="chip-build" x="548" y="135" width="92" height="22" rx="11"></rect>
    <text class="chip-build-t" x="594" y="150" text-anchor="middle">in build</text>

    {/* Kathai Chithiram */}
    <rect class="prod-b" x="405" y="196" width="250" height="56" rx="8"></rect>
    <text class="node prod-t sm" x="422" y="229" text-anchor="start">Kathai Chithiram</text>
    <rect class="chip-build" x="548" y="213" width="92" height="22" rx="11"></rect>
    <text class="chip-build-t" x="594" y="228" text-anchor="middle">in build</text>

    {/* Legend */}
    <line class="ln" x1="196" y1="284" x2="232" y2="284"></line>
    <text x="240" y="288">wired in code today</text>
    <line class="ln dashed" x1="404" y1="284" x2="440" y2="284"></line>
    <text x="448" y="288">planned</text>
  </svg>
</figure>

<style>
  .engine-diagram {
    margin: 1.75rem 0 0;
  }

  .engine-diagram svg {
    display: block;
    width: 100%;
    height: auto;
    font-family: var(--aw-font-heading), ui-sans-serif, system-ui, sans-serif;
  }

  /* Every selector nested under .engine-diagram — the SVG's own bare selectors
     would otherwise repaint the whole document. */
  .engine-diagram text {
    font-size: 12px;
    fill: #475569;
  }
  .engine-diagram .node {
    font-size: 14px;
    font-weight: 600;
  }
  .engine-diagram .node.sm {
    font-size: 13px;
  }
  .engine-diagram .sub {
    font-size: 11px;
  }
  .engine-diagram .elabel {
    font-size: 11px;
    font-style: italic;
    fill: #64748b;
  }
  .engine-diagram .caption {
    font-size: 12.5px;
    font-style: italic;
    fill: #475569;
  }
  .engine-diagram .muted {
    font-size: 11px;
    fill: #94a3b8;
  }
  .engine-diagram .teal-t {
    fill: #115e59;
  }
  .engine-diagram .prod-t {
    fill: #334155;
  }
  .engine-diagram .engine-b {
    fill: #ccfbf1;
    stroke: #5eead4;
  }
  .engine-diagram .prod-b {
    fill: #f8fafc;
    stroke: #e2e8f0;
  }
  .engine-diagram .ln {
    stroke: #64748b;
    stroke-width: 1.25;
    fill: none;
  }
  .engine-diagram .ln.dashed {
    stroke-dasharray: 5 4;
    stroke: #94a3b8;
  }
  .engine-diagram .ah {
    fill: #64748b;
  }
  .engine-diagram .ah-muted {
    fill: #94a3b8;
  }
  .engine-diagram .junction {
    fill: #64748b;
    stroke: none;
  }
  .engine-diagram .chip-live {
    fill: #d1fae5;
    stroke: #6ee7b7;
  }
  .engine-diagram .chip-live-t {
    font-size: 11px;
    fill: #065f46;
  }
  .engine-diagram .chip-build {
    fill: #fef3c7;
    stroke: #fcd34d;
  }
  .engine-diagram .chip-build-t {
    font-size: 11px;
    fill: #92400e;
  }

  /* Keyed to the site's `.dark` class (tailwind darkMode: 'class'), not the OS. */
  :global(html.dark) .engine-diagram text {
    fill: #cbd5e1;
  }
  :global(html.dark) .engine-diagram .caption {
    fill: #94a3b8;
  }
  :global(html.dark) .engine-diagram .muted {
    fill: #64748b;
  }
  :global(html.dark) .engine-diagram .prod-t {
    fill: #e2e8f0;
  }
  :global(html.dark) .engine-diagram .prod-b {
    fill: rgb(148 163 184 / 7%);
    stroke: #334155;
  }
  /* Chips keep their light fills in dark mode, so their dark ink must persist —
     the bare `html.dark ... text` rule above would otherwise wash them out. */
  :global(html.dark) .engine-diagram .teal-t {
    fill: #115e59;
  }
  :global(html.dark) .engine-diagram .chip-live-t {
    fill: #065f46;
  }
  :global(html.dark) .engine-diagram .chip-build-t {
    fill: #92400e;
  }
</style>
