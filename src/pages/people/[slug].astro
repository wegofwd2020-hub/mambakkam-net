---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';

export async function getStaticPaths() {
  const people = await getCollection('people', ({ data }) => !data.draft);
  return people.map((person) => ({
    params: { slug: person.id },
    props: { person },
  }));
}

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/people/*.{jpg,jpeg,png,webp}');

const { person } = Astro.props;
const { Content } = await render(person);
const { name, nameTamil, role, bio, image, links } = person.data;

const allWork = await getCollection('work', ({ data }) => !data.draft && data.author === person.id);
const work = allWork.sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const imageKey = image ? image.replace('~/', '/src/') : null;
const resolvedImage = imageKey && images[imageKey] ? (await images[imageKey]()).default : null;

const metadata = {
  title: name,
  description: bio,
};
---

<Layout metadata={metadata}>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <!-- Header -->
    <header class="mb-12">
      <p class="text-sm font-heading font-medium text-muted uppercase tracking-widest mb-6">People of Mambakkam</p>

      <div class="flex flex-col sm:flex-row gap-8 items-start">
        {
          resolvedImage && (
            <div class="shrink-0">
              <Image
                src={resolvedImage}
                alt={`Photo of ${name}`}
                width={160}
                height={160}
                class="w-40 h-40 rounded-2xl object-cover object-top shadow-md"
              />
            </div>
          )
        }

        <div class="flex-1">
          <h1 class="text-4xl font-heading font-bold text-gray-900 dark:text-white mb-1">
            {name}
          </h1>
          {nameTamil && <p class="text-base text-muted mb-3">{nameTamil}</p>}
          <p class="text-lg font-heading font-medium text-accent mb-6">{role}</p>

          {
            links?.linkedin && (
              <a
                href={links.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 btn btn-primary text-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
                View full CV on LinkedIn
              </a>
            )
          }
        </div>
      </div>
    </header>

    <!-- Bio -->
    <section class="mb-12">
      <p class="text-lg leading-relaxed">{bio}</p>
    </section>

    <!-- Extended content from markdown body -->
    <section class="prose dark:prose-invert max-w-none mb-12">
      <Content />
    </section>

    <!-- Work -->
    {
      work.length > 0 && (
        <section class="mb-12">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-heading font-bold text-gray-900 dark:text-white">Work</h2>
            <a href="/work" class="text-sm font-heading font-medium text-primary hover:underline">
              All work →
            </a>
          </div>
          <div class="space-y-4">
            {work.map((item) => (
              <a
                href={`/work/${item.id}`}
                class="group block border border-gray-200 dark:border-gray-700 rounded-xl p-5 hover:border-primary hover:shadow-sm transition-all duration-200"
              >
                <div class="flex items-center justify-between mb-1">
                  <h3 class="font-heading font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                    {item.data.title}
                  </h3>
                  <span class="text-xs font-mono text-muted capitalize">{item.data.type}</span>
                </div>
                <p class="text-sm text-muted line-clamp-2">{item.data.excerpt}</p>
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {item.data.tags.map((tag) => (
                      <span class="text-xs font-mono px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- LinkedIn CTA -->
    {
      links?.linkedin && (
        <section class="mb-12 rounded-2xl bg-amber-50/60 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800 p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
          <div>
            <p class="font-heading font-semibold text-gray-900 dark:text-white">Looking for the full CV?</p>
            <p class="text-sm text-muted">Experience, projects, and recommendations on LinkedIn.</p>
          </div>
          <a
            href={links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 inline-flex items-center gap-2 btn btn-primary text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            Open LinkedIn
          </a>
        </section>
      )
    }

    <!-- Back -->
    <div class="pt-8 border-t border-gray-200 dark:border-gray-700">
      <a href="/people" class="text-sm font-heading font-medium text-primary hover:underline"> ← All people </a>
    </div>
  </div>
</Layout>
