---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Note from '~/components/widgets/Note.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';

import villageHero from '~/assets/images/village/whatsapp-image-2026-04-28-at-23.06.53.jpeg';

const metadata = {
  title: 'Mambakkam — Village, Land, People',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Mambakkam · Tamil Nadu · India"
    actions={[
      {
        variant: 'primary',
        text: 'The Village',
        href: '/village',
        icon: 'tabler:map-pin',
      },
      {
        text: 'Meet the People',
        href: '/people',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="village-hero-bg absolute inset-0" aria-hidden="true"></div>
    </Fragment>
    <Fragment slot="title">
      <span class="block font-serif font-normal text-6xl sm:text-7xl md:text-8xl leading-none tracking-tight">
        மாம்பாக்கம்
      </span>
    </Fragment>
    <Fragment slot="subtitle">
      A farming village in Kalavai Taluk, near the Palar river — rooted in paddy fields, groundnut, and sugarcane, and
      home to its temples, its land, and its people.
    </Fragment>
    <Fragment slot="content">
      <div
        class="mt-8 flex justify-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <div
          class="inline-flex flex-wrap justify-center items-center gap-x-3 gap-y-1 text-[0.7rem] md:text-xs font-mono uppercase tracking-[0.18em] text-secondary dark:text-primary px-5 py-2 rounded-sm border border-secondary/30 dark:border-primary/30"
        >
          <span class="inline-flex items-center gap-1.5">
            <Icon name="tabler:map-pin-filled" class="w-3 h-3" />
            12.6779°N · 79.3964°E
          </span>
          <span aria-hidden="true" class="text-secondary/40 dark:text-primary/40">·</span>
          <span>Kalavai Taluk</span>
          <span aria-hidden="true" class="text-secondary/40 dark:text-primary/40">·</span>
          <span>Pin 632318</span>
        </div>
      </div>
    </Fragment>
    <Fragment slot="image">
      <figure class="relative">
        <div class="aspect-[16/9] overflow-hidden rounded-lg shadow-xl ring-1 ring-black/10 dark:ring-white/10">
          <Image
            src={villageHero}
            alt="The new temple at Mambakkam under construction — stone pillar in the foreground, bamboo scaffolding around the gopuram"
            class="w-full h-full object-cover object-top"
            widths={[768, 1024, 1600, 2048]}
            sizes="(max-width: 1024px) 100vw, 1024px"
            loading="eager"
            width={1600}
            height={900}
          />
        </div>
        <figcaption
          class="absolute bottom-3 right-3 md:bottom-4 md:right-4 bg-white/90 dark:bg-black/70 backdrop-blur-sm text-[0.65rem] md:text-xs font-mono uppercase tracking-wider text-default px-2.5 py-1 rounded shadow-sm"
        >
          The new temple · 2026
        </figcaption>
      </figure>
    </Fragment>
  </Hero>

  <Note
    title="Welcome to Mambakkam"
    description="This is our village's corner of the web — a place to share what we grow, who we are, and what we're building together."
  />

  <Features
    id="pillars"
    title="One village, many stories"
    columns={3}
    items={[
      {
        title: 'Landmarks',
        description: 'Our temples, our water, our places. Come see the new temple going up — stone by stone.',
        icon: 'tabler:building-arch',
        href: '/landmarks',
      },
      {
        title: 'People',
        description: 'Farmers, engineers, teachers — the people who grew up here and carried Mambakkam with them.',
        icon: 'tabler:users',
        href: '/people',
      },
      {
        title: 'Work',
        description: 'Software and services from people of Mambakkam — built here, offered to the world.',
        icon: 'tabler:briefcase',
        href: '/work',
      },
      {
        title: 'Land',
        description: 'Rice, cotton, sugarcane — the crops our families have grown for generations.',
        icon: 'tabler:plant',
        href: '/land',
      },
      {
        title: 'News',
        description: "What's happening in the village — temple news, seasonal events, community updates.",
        icon: 'tabler:news',
        href: '/news',
      },
    ]}
  />

  <BlogLatestPosts title="Latest from Mambakkam" information="News, updates, and stories from the village." />
</Layout>
